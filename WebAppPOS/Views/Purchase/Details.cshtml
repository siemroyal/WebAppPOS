@model WebAppPOS.Models.Purchase

<div class="container py-4">

    <div class="d-flex justify-content-between mb-3">
        <h3>Purchase Details</h3>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>

    <div class="card p-4 mb-3">
        <div class="row">
            <div class="col-md-3"><b>No:</b> @Model.PurchaseNo</div>
            <div class="col-md-3"><b>Date:</b> @Model.PurchaseDate.ToShortDateString()</div>
            <div class="col-md-3"><b>Supplier:</b> @Model.Suppliers?.SupplierName</div>
            <div class="col-md-3"><b>Status:</b> @Model.PurchaseStatus</div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Total</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        decimal grand = 0;
                    }
                    @foreach (var item in Model.PurchaseDetails)
                    {
                        var total = item.Quantity * item.UnitPrice;
                        grand += total;

                        <tr>
                            <td>@item.Products?.ProductName</td>
                            <td>@item.Quantity</td>
                            <td>$@item.UnitPrice</td>
                            <td>$@total</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="text-end">
                <h4>Total: $@grand</h4>
            </div>

        </div>
    </div>

</div>