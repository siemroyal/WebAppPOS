@model IEnumerable<WebAppPOS.Models.Purchase>

@{
    ViewData["Title"] = "Purchase Management";
    // Calculate total procurement value safely
    var totalProcurementValue = Model?.Sum(p => p.PurchaseDetails?.Sum(d => d.Quantity * d.UnitPrice) ?? 0) ?? 0;
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    body { font-family: 'Inter', sans-serif; background-color: #f8f9fc; color: #334155; }
    .card { border: none; border-radius: 16px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03); }
    
    /* Stats Bar */
    .stat-box { border-left: 4px solid #4e73df; padding: 10px 20px; background: #fff; border-radius: 12px; height: 100%; }
    .stat-title { font-size: 0.7rem; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; }
    .stat-value { font-size: 1.25rem; font-weight: 700; color: #1e293b; }

    /* Table Styling */
    .table thead th { 
        background: #fcfcfd; text-transform: uppercase; font-size: 0.72rem; 
        letter-spacing: 1px; font-weight: 800; color: #64748b; padding: 18px 15px; border: none;
    }
    .table tbody td { padding: 18px 15px; vertical-align: middle; border-bottom: 1px solid #f1f5f9; }
    .table-hover tbody tr:hover { background-color: #f8faff; transition: 0.2s; }

    /* Search & Layout */
    .search-pill { border-radius: 50px; border: 1px solid #e2e8f0; padding-left: 45px; transition: 0.3s; }
    .search-pill:focus { border-color: #4e73df; box-shadow: 0 0 0 4px rgba(78, 115, 223, 0.1); }
    .search-icon { position: absolute; left: 18px; top: 50%; transform: translateY(-50%); color: #94a3b8; z-index: 5; }

    /* Status Badges */
    .badge-soft-success { background: #ecfdf5; color: #10b981; border: 1px solid #d1fae5; }
    .badge-soft-warning { background: #fffbeb; color: #f59e0b; border: 1px solid #fef3c7; }
</style>

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
        <div>
            <h2 class="fw-bold text-dark mb-1">Purchase Management</h2>
            <p class="text-muted small mb-0">Track and manage inventory procurement records.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold">
            <i class="bi bi-plus-lg me-1"></i> New Purchase
        </a>
    </div>

    <!-- Quick Summary Row -->
    <div class="row g-3 mb-5">
        <div class="col-md-3">
            <div class="stat-box shadow-sm">
                <div class="stat-title">Total Purchases</div>
                <div class="stat-value">@(Model?.Count() ?? 0)</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-box shadow-sm" style="border-color: #10b981;">
                <div class="stat-title">Completed</div>
                <div class="stat-value">@(Model?.Count(x => x.PurchaseStatus == WebAppPOS.Models.Enums.PurchaseStatus.Completed) ?? 0)</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-box shadow-sm" style="border-color: #f59e0b;">
                <div class="stat-title">Procurement Value</div>
                <div class="stat-value">$@totalProcurementValue.ToString("N2")</div>
            </div>
        </div>
    </div>

    <!-- Main List Card -->
    <div class="card shadow-sm">
        <div class="card-header bg-white border-0 py-3">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <form asp-action="Index" method="get" class="position-relative">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" name="search" class="form-control form-control-sm search-pill" 
                               placeholder="Search Purchase No or Supplier..." value="@ViewContext.HttpContext.Request.Query["search"]">
                    </form>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Date</th>
                            <th>Purchase No</th>
                            <th>Supplier</th>
                            <th>Grand Total</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                var rowTotal = item.PurchaseDetails?.Sum(d => d.Quantity * d.UnitPrice) ?? 0;
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark">@item.PurchaseDate.ToString("MMM dd, yyyy")</div>
                                        <small class="text-muted">@item.PurchaseDate.ToString("hh:mm tt")</small>
                                    </td>
                                    <td><span class="badge bg-light text-primary border px-3 py-2">#@item.PurchaseNo</span></td>
                                    <td>
                                        <div class="fw-semibold text-dark">@(item.Suppliers?.SupplierName ?? "Walk-in Supplier")</div>
                                        <small class="text-muted">@item.Suppliers?.ShopName</small>
                                    </td>
                                    <td class="fw-bold text-dark">$@rowTotal.ToString("N2")</td>
                                    <td>
                                        @if (item.PurchaseStatus == WebAppPOS.Models.Enums.PurchaseStatus.Completed)
                                        {
                                            <span class="badge badge-soft-success rounded-pill px-3 py-2">
                                                <i class="bi bi-check-circle-fill me-1"></i> Completed
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-soft-warning rounded-pill px-3 py-2 text-dark">
                                                <i class="bi bi-clock-history me-1"></i> Pending
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm rounded-circle border shadow-none" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2" style="border-radius: 12px;">
                                                <li><a class="dropdown-item rounded-3 py-2" asp-action="Details" asp-route-id="@item.PurchaseId"><i class="bi bi-eye me-2 text-info"></i> View Details</a></li>
                                                <li><a class="dropdown-item rounded-3 py-2" asp-action="Edit" asp-route-id="@item.PurchaseId"><i class="bi bi-pencil me-2 text-warning"></i> Modify</a></li>
                                                <li><hr class="dropdown-divider opacity-50"></li>
                                                <li>
                                                    <a class="dropdown-item rounded-3 py-2 text-danger fw-bold" href="javascript:void(0)" onclick="confirmDelete('@item.PurchaseId')">
                                                        <i class="bi bi-trash3 me-2"></i> Delete
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
                                    No purchase records found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Hidden form for deletion *@
<form id="deleteForm" asp-action="Delete" method="post">
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm("Are you sure you want to delete this purchase record? This action cannot be undone.")) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }
    </script>
}