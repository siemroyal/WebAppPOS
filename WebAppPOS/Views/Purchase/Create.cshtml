@model WebAppPOS.Models.Purchase

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    body { font-family: 'Inter', sans-serif; background-color: #f8f9fc; }
    .card { border: none; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .form-label { font-weight: 700; font-size: 0.75rem; text-transform: uppercase; color: #6c757d; }
    .form-control, .form-select { border-radius: 10px; padding: 10px 15px; }
    .btn-primary { background: #4e73df; border: none; border-radius: 10px; }
    .table-thead-custom { background-color: #f8f9fc; font-size: 0.75rem; }
</style>

<div class="container py-4">
<form asp-action="Create" method="post" id="purchaseForm">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0">New Purchase Entry</h3>
        <a asp-action="Index" class="btn btn-light rounded-pill border px-4">Cancel</a>
    </div>

    <div class="card mb-4">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Purchase Number</label>
                    <input asp-for="PurchaseNo" class="form-control bg-light" value="@ViewBag.PurchaseNo" readonly />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Purchase Date</label>
                    <input asp-for="PurchaseDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Supplier</label>
                    <select asp-for="SupplierId" class="form-select" required>
                        <option value="">Select Supplier...</option>
                        @foreach (var s in ViewBag.Suppliers)
                        {
                            <option value="@s.SupplierId">@s.SupplierName</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select asp-for="PurchaseStatus" class="form-select">
                        <option value="0">Pending</option>
                        <option value="1">Completed</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- ITEMS -->
    <div class="card">
        <div class="card-header bg-white py-3">
            <h6 class="m-0 fw-bold text-primary">Itemized Details</h6>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0" id="itemTable">
                    <thead class="table-thead-custom">
                        <tr>
                            <th class="ps-4">Product</th>
                            <th>Quantity</th>
                            <th>Unit Cost</th>
                            <th>Line Total</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr class="item-row">
                            <td class="ps-4">
                                <select name="PurchaseDetails[0].ProductId" class="form-select product-select">
                                    <option value="">Select Product...</option>
                                    @foreach (var p in ViewBag.Products)
                                    {
                                        <option value="@p.Id" data-price="@p.Cost">@p.ProductName</option>
                                    }
                                </select>
                            </td>

                            <td>
                                <input type="number" name="PurchaseDetails[0].StockQty" class="form-control qty" value="1" min="1" />
                            </td>

                            <td>
                                <input type="number" name="PurchaseDetails[0].Price" class="form-control price" step="0.01" />
                            </td>

                            <td>
                                <input type="text" class="form-control border-0 bg-transparent fw-bold row-total" value="0.00" readonly />
                            </td>

                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-link text-danger remove-row p-0">
                                    <i class="bi bi-x-circle-fill fs-5"></i>
                                </button>
                            </td>
                        </tr>
                    </tbody>

                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-0 py-3">
            <button type="button" id="addRow" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                <i class="bi bi-plus-lg me-1"></i> Add Another Product
            </button>
        </div>
    </div>

    <!-- TOTAL -->
    <div class="row mt-4 justify-content-end">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body p-4 d-flex justify-content-between">
                    <span class="fw-bold small">Grand Total</span>
                    <h3 id="grandTotalText">$0.00</h3>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-3">
                Save Purchase
            </button>
        </div>
    </div>

</form>
</div>

@section Scripts {
<script>
    function calculateTotals() {
        let grandTotal = 0;

        document.querySelectorAll(".item-row").forEach(row => {
            let qty = parseFloat(row.querySelector(".qty").value) || 0;
            let price = parseFloat(row.querySelector(".price").value) || 0;
            let total = qty * price;

            row.querySelector(".row-total").value = total.toFixed(2);
            grandTotal += total;
        });

        document.getElementById("grandTotalText").innerText =
            "$" + grandTotal.toFixed(2);
    }

    document.addEventListener("input", function (e) {
        if (e.target.classList.contains("qty") || e.target.classList.contains("price")) {
            calculateTotals();
        }
    });

    document.addEventListener("change", function (e) {
        if (e.target.classList.contains("product-select")) {
            let price = e.target.selectedOptions[0].dataset.price;
            let row = e.target.closest("tr");

            row.querySelector(".price").value = price;
            calculateTotals();
        }
    });

    // ADD ROW
    document.getElementById("addRow").addEventListener("click", function () {
        let index = document.querySelectorAll("#itemTable tbody tr").length;
        let row = document.querySelector(".item-row").cloneNode(true);

        row.querySelectorAll("input, select").forEach(el => {
            if (el.name) {
                el.name = el.name.replace(/\[\d+\]/, `[${index}]`);
            }
            el.value = "";
        });

        row.querySelector(".qty").value = 1;
        row.querySelector(".row-total").value = "0.00";

        document.querySelector("#itemTable tbody").appendChild(row);
    });

    // REMOVE ROW
    document.addEventListener("click", function (e) {
        if (e.target.closest(".remove-row")) {
            let rows = document.querySelectorAll("#itemTable tbody tr");
            if (rows.length > 1) {
                e.target.closest("tr").remove();
                calculateTotals();
            }
        }
    });
</script>
}