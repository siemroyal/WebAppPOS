@model IEnumerable<WebAppPOS.Models.Product>
@{
    ViewData["Title"] = "Product Inventory";
    int index = 1; // Moved outside the loop to fix the counting bug
}

<!-- Load Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-slate-800 mb-1">Product Inventory</h2>
            <p class="text-muted mb-0">Manage your stock, pricing, and product details.</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary rounded-pill px-3 shadow-sm">
                <i class="bi bi-download me-1"></i> Export
            </button>
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold">
                <i class="bi bi-plus-lg me-1"></i> Add New Product
            </a>
        </div>
    </div>

    <!-- Quick Stats Summary -->
    <div class="row g-4 mb-4">
        <div class="col-6 col-md-3">
            <div class="stats-card p-3 shadow-sm rounded-4 bg-white border-start border-primary border-4">
                <small class="text-muted fw-bold text-uppercase">Total Items</small>
                <h4 class="fw-bold mb-0">@Model?.Count()</h4>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stats-card p-3 shadow-sm rounded-4 bg-white border-start border-warning border-4">
                <small class="text-muted fw-bold text-uppercase">Low Stock</small>
                <h4 class="fw-bold mb-0">@Model?.Count(x => x.StockQty < 10)</h4>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stats-card p-3 shadow-sm rounded-4 bg-white border-start border-success border-4">
                <small class="text-muted fw-bold text-uppercase">Inventory Value</small>
                <h4 class="fw-bold mb-0">@Model?.Sum(x => x.StockQty * x.Cost).ToString("C2")</h4>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stats-card p-3 shadow-sm rounded-4 bg-white border-start border-info border-4">
                <small class="text-muted fw-bold text-uppercase">Categories</small>
                <h4 class="fw-bold mb-0">@Model?.Select(x => x.CategoryId).Distinct().Count()</h4>
            </div>
        </div>
    </div>

    <!-- Main Content Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-search"></i></span>
                        <input type="text" id="tableSearch" class="form-control border-start-0 shadow-none" placeholder="Search products...">
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="productTable">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">No</th>
                        <th>Product</th>
                        <th>Code</th>
                        <th>Category</th>
                        <th>Stock</th>
                        <th>Cost</th>
                        <th>Price</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var product in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">@index</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-wrapper me-3">
                                            <img src="@Url.Content(string.IsNullOrEmpty(product.ProductUrl) ? "~/uploads/products/default.jpg" : product.ProductUrl)" 
                                                 class="rounded-3 shadow-sm border" width="45" height="45" style="object-fit: cover;" alt="Product">
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@product.ProductName</div>
                                            <small class="text-muted">@product.Unit?.UnitName</small>
                                        </div>
                                    </div>
                                </td>
                                <td><code class="text-indigo fw-medium">@product.ProductCode</code></td>
                                <td><span class="badge bg-light text-dark border fw-normal">@product.Category?.CategoryName</span></td>
                                <td>
                                    @if (product.StockQty < 10)
                                    {
                                        <span class="text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i>@product.StockQty</span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-bold">@product.StockQty</span>
                                    }
                                </td>
                                <td class="text-muted">@product.Cost.ToString("N2")</td>
                                <td class="fw-bold text-dark">@product.Price.ToString("N2")</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-light border shadow-sm text-primary" title="Edit">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-light border shadow-sm text-info" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-light border shadow-sm text-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            index++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5">
                                <i class="bi bi-box-seam text-muted display-1"></i>
                                <p class="mt-3 text-muted">No products found in the database.</p>
                                <a asp-action="Create" class="btn btn-primary btn-sm rounded-pill">Add Your First Product</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white border-0 py-3">
            <p class="small text-muted mb-0">Showing @Model?.Count() products in inventory.</p>
        </div>
    </div>
</div>

<style>
    :root {
        --indigo: #4361ee;
        --slate-800: #1e293b;
    }

    body {
        background-color: #f8fafc;
        color: #334155;
    }

    .text-indigo { color: var(--indigo); }

    .stats-card {
        border: none;
        transition: transform 0.2s;
    }
    .stats-card:hover { transform: translateY(-3px); }

    .table thead th {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
        color: #64748b;
        border-top: none;
    }

    .table tbody td {
        border-color: #f1f5f9;
        font-size: 0.9rem;
    }

    .btn-light {
        background: white;
    }

    .btn-primary {
        background-color: var(--indigo);
        border-color: var(--indigo);
    }

    #tableSearch:focus {
        border-color: var(--indigo);
    }
</style>

@section Scripts {
    <script>
        // Simple client-side search
        document.getElementById('tableSearch').addEventListener('keyup', function() {
            var input = this.value.toLowerCase();
            var rows = document.querySelectorAll('#productTable tbody tr');
            
            rows.forEach(row => {
                var text = row.textContent.toLowerCase();
                row.style.display = text.includes(input) ? '' : 'none';
            });
        });
    </script>
}