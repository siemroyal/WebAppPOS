@model IEnumerable<WebAppPOS.Models.Customer>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-dark mb-1">Customer Directory</h3>
            <p class="text-muted small">Manage your client relationships and account details.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-person-plus-fill me-2"></i>Add New Customer
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4 py-3 text-muted small text-uppercase">Customer</th>
                            <th class="py-3 text-muted small text-uppercase">Contact</th>
                            <th class="py-3 text-muted small text-uppercase">Type</th>
                            <th class="py-3 text-muted small text-uppercase">Bank info</th>
                            <th class="py-3 text-muted small text-uppercase text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <img src="@(string.IsNullOrEmpty(item.PhotoUrl) ? "https://ui-avatars.com/api/?name=" + item.CustomerName : "/" + item.PhotoUrl)" 
                                             class="rounded-circle me-3 border" width="45" height="45" style="object-fit: cover;" />
                                        <div>
                                            <div class="fw-bold text-dark">@item.CustomerName</div>
                                            <small class="text-muted">ID: #CUST-@item.CustomerId.ToString("D4")</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small"><i class="bi bi-telephone me-2 text-primary"></i>@item.Phone</div>
                                    <div class="small text-muted"><i class="bi bi-envelope me-2"></i>@item.Email</div>
                                </td>
                                <td>
                                    <span class="badge @(item.Type == "VIP" ? "bg-warning text-dark" : "bg-info-subtle text-info") rounded-pill px-3">
                                        @item.Type
                                    </span>
                                </td>
                                <td>
                                    <div class="small fw-bold">@item.BankName</div>
                                    <div class="text-muted small">@item.AccountNumber</div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-circle" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                            <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.CustomerId"><i class="bi bi-eye me-2 text-info"></i> View Details</a></li>
                                            <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.CustomerId"><i class="bi bi-pencil me-2 text-warning"></i> Edit Profile</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <form asp-action="Delete" asp-route-id="@item.CustomerId" method="post" onsubmit="return confirm('Delete this customer?')">
                                                    <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i> Remove</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>